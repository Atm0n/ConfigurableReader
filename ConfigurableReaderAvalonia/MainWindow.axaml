<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
        x:Class="ConfigurableReaderAvalonia.MainWindow"
        Title="Single Line Reader"
        WindowState="Maximized"
        Background="#1E1E1E"
        Foreground="#F1F1F1"
        KeyDown="Window_KeyDown"
        Closing="Window_Closing">

    <Window.Resources>
        <LinearGradientBrush x:Key="EdgeFadeMask" StartPoint="0%,50%" EndPoint="100%,50%">
            <GradientStop Color="Transparent" Offset="0"/>
            <GradientStop Color="Black" Offset="0.01"/>
            <GradientStop Color="Black" Offset="0.99"/>
            <GradientStop Color="Transparent" Offset="1"/>
        </LinearGradientBrush>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="#F1F1F1"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#505050"/>
        </Style>

        <Style Selector="TextBlock.LabelStyle">
            <Setter Property="Foreground" Value="#F1F1F1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style Selector="Border.GroupBorder">
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Collapsible Control Panel -->
        <Expander Name="SettingsExpander" Grid.Row="0" Header="Settings &amp; Controls" 
                  ExpandDirection="Down" IsExpanded="True"
                  Background="#2D2D30" 
                  Foreground="#F1F1F1"
                  BorderThickness="0,0,0,1" BorderBrush="#3E3E42">
            <Border Padding="10">
                <WrapPanel Orientation="Horizontal">
                
                    <!-- File Group -->
                    <Border Classes="GroupBorder">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Open File" Click="OpenFileButton_Click" Focusable="False"/>
                        </StackPanel>
                    </Border>

                    <!-- Playback Group -->
                    <Border Classes="GroupBorder">
                        <StackPanel Orientation="Horizontal">
                            <Button Name="StartStopButton" Content="Start" Click="StartStopButton_Click" Focusable="False" Width="60"/>
                            <Button Name="ReverseButton" Content="Reverse" Click="ReverseButton_Click" Focusable="False"/>
                            <TextBlock Text="Speed:" Classes="LabelStyle"/>
                            <Slider Name="SpeedSlider" Minimum="0" Maximum="1000" Value="100" Width="150" Focusable="False"/>
                        </StackPanel>
                    </Border>

                    <!-- Appearance Group -->
                    <Border Classes="GroupBorder">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Font:" Classes="LabelStyle"/>
                            <ComboBox Name="FontComboBox" Width="150" SelectionChanged="FontComboBox_SelectionChanged" Focusable="False"/>

                            <CheckBox Name="FadeCheckBox" Content="Edge Fade" VerticalAlignment="Center" Margin="10,0" 
                                      IsCheckedChanged="FadeCheckBox_IsCheckedChanged" Focusable="False" Foreground="#F1F1F1"/>

                            <TextBlock Text="Text:" Classes="LabelStyle"/>
                            <ColorPicker Name="TextColorPicker" Width="60" ColorChanged="TextColorPicker_ColorChanged" Focusable="False"/>
                        
                            <TextBlock Text="BG:" Classes="LabelStyle"/>
                            <ColorPicker Name="BackgroundColorPicker" Width="60" ColorChanged="BackgroundColorPicker_ColorChanged" Focusable="False"/>
                        
                            <TextBlock Text="Size:" Classes="LabelStyle"/>
                            <NumericUpDown Name="FontSizeNumeric" Width="100" Minimum="10" Maximum="800" 
                                           Value="48" Focusable="False"/>
                        </StackPanel>
                    </Border>

                    <!-- Info Group -->
                    <Border Classes="GroupBorder">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Info" Click="InfoButton_Click" Focusable="False"/>
                        </StackPanel>
                    </Border>

                </WrapPanel>
            </Border>
        </Expander>

        <!-- Main Reading Area -->
        <Canvas Name="ReadingAreaCanvas" Grid.Row="1" ClipToBounds="True" Background="Transparent">
            <TextBlock 
                Name="MainTextBlock" 
                Text="ConfigurableReader" 
                FontSize="48" 
                Padding="0"
                VerticalAlignment="Center"
                TextAlignment="Left" 
                TextWrapping="NoWrap"
                Focusable="False">
            </TextBlock>
        </Canvas>

        <!-- Progress Area -->
        <Border Grid.Row="2" Background="#2D2D30" Padding="10" BorderThickness="0,1,0,0" BorderBrush="#3E3E42">
            <Grid ColumnDefinitions="200,*,100,Auto">
                <TextBlock Name="BookNameText" Grid.Column="0" Text="No file opened" VerticalAlignment="Center" Foreground="#F1F1F1" TextTrimming="CharacterEllipsis"/>
                <Slider Name="TextSlider" Grid.Column="1" Minimum="0" Maximum="100" ValueChanged="TextSlider_ValueChanged" Focusable="False"/>
                <TextBlock Name="PercentageText" Grid.Column="2" Text="0%" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#F1F1F1"/>
                <TextBlock Name="InputModeText" Grid.Column="3" Text="⌨️" FontSize="20" VerticalAlignment="Center" Margin="10,0" ToolTip.Tip="Keyboard Mode"/>
            </Grid>
        </Border>

    </Grid>
</Window>
