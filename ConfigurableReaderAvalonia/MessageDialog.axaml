<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ConfigurableReaderAvalonia.MessageDialog"
        Title="Notification" Width="300" Height="150"
        WindowStartupLocation="CenterOwner"
        WindowDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent">
    <Border Background="#2D2D30" BorderBrush="#007ACC" BorderThickness="2" CornerRadius="8">
        <Grid RowDefinitions="*,Auto" Margin="15">
            <TextBlock Name="MessageText" Text="Message" Foreground="White" FontSize="14" 
                       TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
            
            <Button Grid.Row="1" Content="OK" Width="80" Height="30" Margin="0,10,0,0"
                    Click="OkButton_Click" HorizontalAlignment="Center" Background="#3E3E42" Foreground="White"/>
        </Grid>
    </Border>
</Window>
