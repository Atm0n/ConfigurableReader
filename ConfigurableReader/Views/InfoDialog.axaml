<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ConfigurableReader.Views.InfoDialog"
        Title="About ConfigurableReader" Height="580" Width="420"
        WindowStartupLocation="CenterOwner"
        Background="Transparent" Foreground="#F1F1F1"
        TransparencyLevelHint="AcrylicBlur"
        ExtendClientAreaToDecorationsHint="True">
    
    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBlock.HeaderStyle">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#4DACFF"/>
            <Setter Property="Margin" Value="0,20,0,5"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.SubHeaderStyle">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,15,0,5"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
        </Style>
    </Window.Styles>
    
    <ExperimentalAcrylicBorder CornerRadius="0">
        <ExperimentalAcrylicBorder.Material>
            <ExperimentalAcrylicMaterial BackgroundSource="Digger" TintColor="#1A1A1A" TintOpacity="1" MaterialOpacity="0.8" />
        </ExperimentalAcrylicBorder.Material>

        <Grid Margin="30" RowDefinitions="Auto,*,Auto">
            <StackPanel Grid.Row="0" Margin="0,20,0,10">
                <TextBlock Text="ConfigurableReader" Classes="HeaderStyle"/>
                <TextBlock Text="Version 1.1.0" FontSize="12" Opacity="0.7" HorizontalAlignment="Center" Margin="0,-5,0,0"/>
                <TextBlock Text="Made by Nil Riera" FontSize="13" FontStyle="Italic" Opacity="0.9" HorizontalAlignment="Center" Margin="0,2,0,10"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{DynamicResource AppDescription}" 
                               TextWrapping="Wrap" Margin="0,5,0,15" TextAlignment="Center" LineHeight="20"/>

                    <TextBlock Text="{DynamicResource SupportedFormatsHeader}" Classes="SubHeaderStyle"/>
                    <TextBlock Text="• TXT, EPUB, PDF, DOCX, Markdown (.md)" Margin="10,0" Opacity="0.9"/>

                    <TextBlock Text="{DynamicResource KeyboardControlsHeader}" Classes="SubHeaderStyle"/>
                    <StackPanel Margin="10,0">
                        <TextBlock Text="• Space: Play / Pause" />
                        <TextBlock Text="• Left / Right: Forward / Backward" />
                        <TextBlock Text="• Up / Down: Adjust Font Size" />
                        <TextBlock Text="• R: Toggle Direction" />
                        <TextBlock Text="• F: Toggle Edge Fade" />
                        <TextBlock Text="• S: Toggle Settings" />
                        <TextBlock Text="• I: Show Info" />
                        <TextBlock Text="• +/-: Adjust Speed" />
                    </StackPanel>

                    <TextBlock Text="{DynamicResource GamepadControlsHeader}" Classes="SubHeaderStyle"/>
                    <StackPanel Margin="10,0">
                        <TextBlock Text="• A / B: Play / Pause" />
                        <TextBlock Text="• DPad Up / Down: Font Size" />
                        <TextBlock Text="• DPad Left / Right: Direction" />
                        <TextBlock Text="• X / Y: Direction / Edge Fade" />
                        <TextBlock Text="• LB / RB: Adjust Speed" />
                        <TextBlock Text="• LT / RT: Rewind / Fast-Forward" />
                        <TextBlock Text="• Double-tap Triggers: Speed Boost" />
                        <TextBlock Text="• Look for ⌨️/🎮 icon for status" />
                    </StackPanel>

                    <TextBlock Text="{DynamicResource LicensesHeader}" Classes="SubHeaderStyle" Margin="0,20,0,5"/>
                    <TextBlock Text="This project is licensed under the MIT License." Opacity="0.8" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="{DynamicResource ThirdPartyHeader}" Classes="SubHeaderStyle"/>
                    <StackPanel Margin="10,0">
                        <TextBlock Text="• Avalonia UI (MIT)" />
                        <TextBlock Text="• PdfPig (MIT)" />
                        <TextBlock Text="• Markdig (BSD-2)" />
                        <TextBlock Text="• OpenXML SDK (MIT)" />
                        <TextBlock Text="• HtmlAgilityPack (MIT)" />
                        <TextBlock Text="• HIDDevices / HIDSharp (Apache 2.0)" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <Button Grid.Row="2" Content="{DynamicResource Close}" Width="120" HorizontalAlignment="Center" Margin="0,15,0,0" 
                    Click="CloseButton_Click" Padding="10,8" HorizontalContentAlignment="Center"/>
        </Grid>
    </ExperimentalAcrylicBorder>
</Window>
