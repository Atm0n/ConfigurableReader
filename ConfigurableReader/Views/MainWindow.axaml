<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
        x:Class="ConfigurableReader.Views.MainWindow"
        Title="ConfigurableReader"
        WindowState="Maximized"
        Background="#1E1E1E"
        Foreground="#F1F1F1"
        KeyDown="Window_KeyDown"
        Closing="Window_Closing">

    <Window.Resources>
        <LinearGradientBrush x:Key="EdgeFadeMask" StartPoint="0%,50%" EndPoint="100%,50%">
            <GradientStop Color="Transparent" Offset="0"/>
            <GradientStop Color="Black" Offset="0.01"/>
            <GradientStop Color="Black" Offset="0.99"/>
            <GradientStop Color="Transparent" Offset="1"/>
        </LinearGradientBrush>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="#F1F1F1"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#505050"/>
        </Style>

        <Style Selector="TextBlock.LabelStyle">
            <Setter Property="Foreground" Value="#F1F1F1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="10,0,5,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style Selector="Border.GroupBorder">
            <Setter Property="BorderBrush" Value="#4A4A4C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Background" Value="#333337"/>
        </Style>

        <Style Selector="Slider">
            <Setter Property="Margin" Value="10,0"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Margin" Value="5,0"/>
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="Margin" Value="5,0"/>
        </Style>
        <Style Selector="ColorPicker">
            <Setter Property="Margin" Value="5,0"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Collapsible Control Panel -->
        <Expander Name="SettingsExpander" Grid.Row="0" Header="{DynamicResource SettingsHeader}" 
                  ExpandDirection="Down" IsExpanded="True"
                  Background="#2D2D30" 
                  Foreground="#F1F1F1"
                  BorderThickness="0,0,0,1" BorderBrush="#3E3E42">
            <Border Padding="15">
                <WrapPanel Orientation="Horizontal">
                
                    <!-- File Group -->
                    <Border Classes="GroupBorder">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Button Content="{DynamicResource OpenFile}" Click="OpenFileButton_Click" Focusable="False"/>
                        </StackPanel>
                    </Border>

                    <!-- Playback Group -->
                    <Border Classes="GroupBorder">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Name="StartStopButton" Content="{DynamicResource Start}" Click="StartStopButton_Click" Focusable="False" Width="70"/>
                            <Button Name="ReverseButton" Content="{DynamicResource Reverse}" Click="ReverseButton_Click" Focusable="False"/>
                            <TextBlock Text="{DynamicResource Speed}" Classes="LabelStyle"/>
                            <Slider Name="SpeedSlider" Minimum="0" Maximum="1000" Value="100" Width="150" Focusable="False" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Appearance Group -->
                    <Border Classes="GroupBorder">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource Font}" Classes="LabelStyle"/>
                                <ComboBox Name="FontComboBox" Width="180" SelectionChanged="FontComboBox_SelectionChanged" Focusable="False"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Language:" Classes="LabelStyle"/>
                                <ComboBox Name="LanguageComboBox" Width="100" SelectionChanged="LanguageComboBox_SelectionChanged" Focusable="False">
                                    <ComboBoxItem Content="English" Tag="en-US"/>
                                    <ComboBoxItem Content="Español" Tag="es-ES"/>
                                    <ComboBoxItem Content="Català" Tag="ca-ES"/>
                                </ComboBox>
                            </StackPanel>

                            <CheckBox Name="FadeCheckBox" Content="{DynamicResource EdgeFade}" VerticalAlignment="Center" Margin="10,0" 
                                      IsCheckedChanged="FadeCheckBox_IsCheckedChanged" Focusable="False" Foreground="#F1F1F1"/>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource TextColor}" Classes="LabelStyle"/>
                                <ColorPicker Name="TextColorPicker" Width="60" ColorChanged="TextColorPicker_ColorChanged" Focusable="False"/>
                            </StackPanel>
                        
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource BackgroundColor}" Classes="LabelStyle"/>
                                <ColorPicker Name="BackgroundColorPicker" Width="60" ColorChanged="BackgroundColorPicker_ColorChanged" Focusable="False"/>
                            </StackPanel>
                        
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource FontSize}" Classes="LabelStyle"/>
                                <NumericUpDown Name="FontSizeNumeric" Width="110" Minimum="10" Maximum="800" 
                                               Value="48" Focusable="False" ValueChanged="FontSizeNumeric_ValueChanged"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Info Group -->
                    <Border Classes="GroupBorder">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBox Name="SearchTextBox" Width="150" PlaceholderText="{DynamicResource SearchWatermark}" 
                                     KeyDown="SearchTextBox_KeyDown" Focusable="True"/>
                            <Button Name="SearchButton" Content="{DynamicResource SearchNext}" Click="SearchButton_Click" Focusable="False"/>
                        </StackPanel>
                    </Border>

                    <!-- Info Group -->
                    <Border Classes="GroupBorder">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="{DynamicResource Info}" Click="InfoButton_Click" Focusable="False"/>
                        </StackPanel>
                    </Border>

                </WrapPanel>
            </Border>
        </Expander>

        <!-- Main Reading Area -->
        <Canvas Name="ReadingAreaCanvas" Grid.Row="1" ClipToBounds="True" Background="Transparent" UseLayoutRounding="False">
            <TextBlock 
                Name="MainTextBlock" 
                Text="ConfigurableReader" 
                FontSize="48" 
                Padding="0"
                VerticalAlignment="Center"
                TextAlignment="Left" 
                TextWrapping="NoWrap"
                UseLayoutRounding="False"
                Focusable="False">
            </TextBlock>
        </Canvas>

        <!-- Progress Area -->
        <Border Grid.Row="2" Background="#2D2D30" Padding="10" BorderThickness="0,1,0,0" BorderBrush="#3E3E42">
            <Grid ColumnDefinitions="200,*,100,Auto">
                <TextBlock Name="BookNameText" Grid.Column="0" Text="{DynamicResource NoFileOpened}" VerticalAlignment="Center" Foreground="#F1F1F1" TextTrimming="CharacterEllipsis"/>
                <Slider Name="TextSlider" Grid.Column="1" Minimum="0" Maximum="100" ValueChanged="TextSlider_ValueChanged" Focusable="False"/>
                <TextBlock Name="PercentageText" Grid.Column="2" Text="0%" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#F1F1F1"/>
                <TextBlock Name="InputModeText" Grid.Column="3" Text="⌨️" FontSize="20" VerticalAlignment="Center" Margin="10,0" ToolTip.Tip="{DynamicResource KeyboardMode}"/>
            </Grid>
        </Border>

    </Grid>
</Window>
