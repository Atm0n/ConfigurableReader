<Window x:Class="ConfigurableReader.InfoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About ConfigurableReader" Height="550" Width="400"
        WindowStyle="ToolWindow" ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="#1E1E1E" Foreground="#F1F1F1">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#007ACC"/>
            <Setter Property="Margin" Value="0,15,0,5"/>
        </Style>
        <Style x:Key="SubHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,2"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="ConfigurableReader" Style="{StaticResource HeaderStyle}"/>
                <TextBlock Text="Version 0.1.1" FontSize="11" Opacity="0.7" Margin="0,-5,0,0"/>
                <TextBlock Text="Made by Nil Riera" FontSize="12" FontStyle="Italic" Opacity="0.9" Margin="0,2,0,10"/>
                
                <TextBlock Text="A highly customizable text reader for Windows designed for a comfortable and hands-free reading experience." 
                           TextWrapping="Wrap" Margin="0,5,0,10"/>

                <TextBlock Text="Controls" Style="{StaticResource HeaderStyle}"/>
                
                <TextBlock Text="Keyboard" Style="{StaticResource SubHeaderStyle}"/>
                <StackPanel Margin="10,0">
                    <TextBlock Text="• Space: Play / Pause" />
                    <TextBlock Text="• Left / Right: Forward / Backward" />
                    <TextBlock Text="• Up / Down: Adjust Font Size" />
                    <TextBlock Text="• R: Toggle Direction" />
                    <TextBlock Text="• F: Toggle Edge Fade" />
                    <TextBlock Text="• S: Toggle Settings" />
                    <TextBlock Text="• I: Show Info" />
                    <TextBlock Text="• +/-: Adjust Speed" />
                </StackPanel>

                <TextBlock Text="Xbox Controller" Style="{StaticResource SubHeaderStyle}"/>
                <StackPanel Margin="10,0">
                    <TextBlock Text="• A / B Button: Play / Pause" />
                    <TextBlock Text="• DPad Left / Right: Forward / Backward" />
                    <TextBlock Text="• DPad Up / Down: Adjust Font Size" />
                    <TextBlock Text="• X Button: Toggle Direction" />
                    <TextBlock Text="• Y Button: Toggle Edge Fade" />
                    <TextBlock Text="• LB / RB (Bumpers): Adjust Speed" />
                    <TextBlock Text="• Start: Toggle Settings" />
                    <TextBlock Text="• Back: Show Info" />
                </StackPanel>

                <TextBlock Text="License" Style="{StaticResource HeaderStyle}"/>
                <TextBlock Text="Licensed under the MIT License." Opacity="0.8"/>
                <TextBlock Text="Uses Extended.Wpf.Toolkit and SharpDX.XInput." FontSize="11" Opacity="0.6"/>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="1" Content="Close" Width="100" HorizontalAlignment="Right" Margin="0,10,0,0" 
                Click="CloseButton_Click" Padding="10,5">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="#3E3E42"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#505050"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Window>