<Window 
    x:Class="ConfigurableReader.MainWindow" 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
    xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit" 
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
    xmlns:local="clr-namespace:ConfigurableReader"
    Title="Single Line Reader" 
    Height="600" 
    Width="1000" 
    Closing="Window_Closing" 
    KeyDown="Window_KeyDown"
    WindowState="Maximized"
    Focusable="True"
    Background="#1E1E1E"
    Foreground="#F1F1F1"
    >
    <Window.Resources>
        <!-- Modern Colors -->
        <SolidColorBrush x:Key="PrimaryBackground" Color="#2D2D30"/>
        <SolidColorBrush x:Key="SecondaryBackground" Color="#3E3E42"/>
        <SolidColorBrush x:Key="AccentColor" Color="#007ACC"/>
        <SolidColorBrush x:Key="TextForeground" Color="#F1F1F1"/>
        <SolidColorBrush x:Key="ButtonHover" Color="#505050"/>

        <!-- Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SecondaryBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextForeground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource ButtonHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slider Style -->
        <Style TargetType="Slider">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="10,5"/>
        </Style>

        <!-- TextBlock Style -->
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="{StaticResource TextForeground}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Group Container Style -->
        <Style TargetType="Border" x:Key="GroupBorder">
            <Setter Property="BorderBrush" Value="{StaticResource SecondaryBackground}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Collapsible Control Panel -->
        <Expander Grid.Row="0" Header="Settings &amp; Controls" 
                  ExpandDirection="Down" IsExpanded="True"
                  Background="{StaticResource PrimaryBackground}" 
                  Foreground="{StaticResource TextForeground}"
                  BorderThickness="0,0,0,1" BorderBrush="{StaticResource SecondaryBackground}">
            <Border Padding="10">
                <WrapPanel Orientation="Horizontal">
                
                    <!-- File Group -->
                    <Border Style="{StaticResource GroupBorder}">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Open File" Click="OpenFileButton_Click" Focusable="False"/>
                        </StackPanel>
                    </Border>

                    <!-- Playback Group -->
                    <Border Style="{StaticResource GroupBorder}">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="StartStopButton" Content="Start" Click="StartStopButton_Click" Focusable="False" Width="60"/>
                            <Button x:Name="ReverseButton" Content="Reverse" Click="ReverseButton_Click" Focusable="False"/>
                            <TextBlock Text="Speed:" Style="{StaticResource LabelStyle}"/>
                            <Slider x:Name="SpeedSlider" Minimum="0" Maximum="0.4" ValueChanged="SpeedSlider_ValueChanged" Width="150" Focusable="False"/>
                        </StackPanel>
                    </Border>

                    <!-- Appearance Group -->
                    <Border Style="{StaticResource GroupBorder}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Text:" Style="{StaticResource LabelStyle}"/>
                            <xctk:ColorPicker x:Name="ColorPicker" Width="45" SelectedColorChanged="ColorPicker_SelectedColorChanged" Focusable="False"/>
                        
                            <TextBlock Text="BG:" Style="{StaticResource LabelStyle}"/>
                            <xctk:ColorPicker x:Name="BackgroundColorPicker" Width="45" SelectedColorChanged="BackgroundColorPicker_SelectedColorChanged" Focusable="False"/>
                        
                            <TextBlock Text="Font Size:" Style="{StaticResource LabelStyle}"/>
                            <xctk:IntegerUpDown x:Name="FontSizeSlider" Width="70" Minimum="10" Maximum="800" 
                                                Value="{Binding ElementName=TextBlock, Path=FontSize, Mode=TwoWay}" Focusable="False"/>
                        </StackPanel>
                    </Border>

                </WrapPanel>
            </Border>
        </Expander>

        <!-- Main Reading Area -->
        <Grid Grid.Row="1" VerticalAlignment="Center">
            <TextBlock 
                x:Name="TextBlock" 
                Text="ConfigurableReader" 
                FontSize="48" 
                TextAlignment="Center" 
                TextWrapping="NoWrap"
                Focusable="False"
            />
        </Grid>

        <!-- Progress Area -->
        <Border Grid.Row="2" Background="{StaticResource PrimaryBackground}" Padding="10" BorderThickness="0,1,0,0" BorderBrush="{StaticResource SecondaryBackground}">
            <Slider x:Name="TextSlider" Minimum="0" Maximum="100" Interval="1" ValueChanged="TextSlider_ValueChanged" Focusable="False"/>
        </Border>

    </Grid>
</Window>